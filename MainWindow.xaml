<Window x:Class="PureAudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PureAudio.ViewModels"
        xmlns:helpers="clr-namespace:PureAudio.Helpers"
        xmlns:controls="clr-namespace:PureAudio.Controls"
        mc:Ignorable="d"
        Title="PureAudio" Width="960"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}" WindowStyle="None" AllowsTransparency="False"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <!-- Main Content (220px) -->
        <Border Grid.Row="0" Height="220" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="640" /> <!-- Display Area ~2/3 -->
                    <ColumnDefinition Width="270" /> <!-- Control Panel -->
                    <ColumnDefinition Width="50" /> <!-- Window buttons -->
                </Grid.ColumnDefinitions>

                <!-- Left Side: Display Area -->
                <Grid Grid.Column="0" Margin="10,5,5,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" /> <!-- Cover Art -->
                    <ColumnDefinition Width="*" /> <!-- Info -->
                    <ColumnDefinition Width="260" /> <!-- FFT Spectrum -->
                    </Grid.ColumnDefinitions>

                    <!-- Cover Art -->
                    <Border Grid.Row="0" Grid.Column="0" Width="180" Height="180" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Top" Margin="0,8,0,0">
                        <Grid>
                            <Image Source="{Binding CoverPath}" Width="178" Height="178" Stretch="UniformToFill">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <Trigger Property="Source" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBlock Text="{Binding NoCoverText}" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Marquee Track Info (spans Info + FFT columns, 435px wide, aligned to left edge of info block) -->
                    <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" 
                               Text="{Binding MarqueeDisplayText}" Foreground="{DynamicResource AccentBrush}" FontSize="14" 
                               TextTrimming="CharacterEllipsis" Width="435" Margin="10,5,0,5" 
                               HorizontalAlignment="Left" VerticalAlignment="Top" />

                    <!-- Info Area (right of cover) -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <!-- Timer Display -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ElapsedText}" Foreground="{DynamicResource AccentBrush}" FontSize="28" FontFamily="Consolas" />
                            <TextBlock Grid.Column="2" Text="/" Foreground="{DynamicResource AccentBrush}" FontSize="28" />
                            <TextBlock Grid.Column="3" Text="{Binding TotalDurationText}" Foreground="{DynamicResource AccentBrush}" FontSize="28" FontFamily="Consolas" />
                        </Grid>

                        <!-- Bitrate -->
                        <TextBlock Text="{Binding BitrateValue, StringFormat='{}{0} kbps'}" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,5,0,0" />

                        <!-- Status Indicators: Row 1 - WASAPI + Gapless (always orange) -->
                        <WrapPanel Margin="0,5,0,0">
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="3" Padding="4,2" Margin="0,0,4,0">
                                <TextBlock Text="{Binding WasapiModeText}" Foreground="{DynamicResource AccentBrush}" FontSize="11" />
                            </Border>
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="3" Padding="4,2" Margin="0,0,4,0">
                                <TextBlock Text="{Binding GaplessText}" Foreground="{DynamicResource AccentBrush}" FontSize="11" />
                            </Border>
                        </WrapPanel>

                        <!-- Status Indicators: Row 2 - Play/Pause/Stop (active orange, inactive gray) -->
                        <WrapPanel Margin="0,4,0,0">
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,4,0">
                                <TextBlock Text="►" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding PlayIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,4,0">
                                <TextBlock Text="❚❚" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding PauseIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6,2">
                                <TextBlock Text="■" FontSize="11" FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding StopIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                        </WrapPanel>

                        <!-- Status Indicators: Row 3 - Hires / MP3 (active orange, inactive gray) -->
                        <WrapPanel Margin="0,4,0,0">
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,4,0">
                                <TextBlock Text="Hires" FontSize="11">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding HiresIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource ButtonBgBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="3" Padding="6,2">
                                <TextBlock Text="MP3" FontSize="11">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding Mp3IndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <!-- FFT Spectrum (130px height, 44px top margin) -->
                    <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="3" Height="130" Margin="5,44,0,0" VerticalAlignment="Top" x:Name="FftBorder">
                        <Grid x:Name="FftContainer" />
                    </Border>

                    <!-- Progress Bar (under Info + FFT columns only, not under Cover) -->
                    <Slider Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" 
                            Value="{Binding Progress}" Minimum="0" Maximum="1" Margin="10,-4,0,0"
                            Thumb.DragStarted="ProgressSlider_DragStarted"
                            Thumb.DragCompleted="ProgressSlider_DragCompleted"
                            PreviewMouseDown="ProgressSlider_PreviewMouseDown" />
                </Grid>

                <!-- Right Side: Control Panel (320px area, actual controls 220x260) -->
                <Grid Grid.Column="1" Width="220" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- Row 1: WASAPI + Gapless buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Width="108" Height="28" Margin="0,0,4,0" 
                                    Content="{Binding WasapiModeText}" 
                                    Command="{Binding ToggleWasapiCommand}" FontSize="11" />
                            <Button Width="108" Height="28" 
                                    Content="{Binding GaplessText}" 
                                    Command="{Binding ToggleGaplessCommand}" FontSize="11">
                                <Button.Foreground>
                                    <SolidColorBrush Color="{Binding GaplessTextColor}" />
                                </Button.Foreground>
                            </Button>
                        </StackPanel>

                        <!-- Row 2: Transport controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Width="52" Height="44" Margin="0,0,4,0"
                                    Content="◄◄" Command="{Binding PreviousCommand}" FontSize="14" />
                            <Button Width="52" Height="44" Margin="0,0,4,0"
                                    Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource AccentBrush}"
                                    Content="{Binding PlayPauseIcon}" Command="{Binding PlayPauseCommand}" FontSize="14" />
                            <Button Width="52" Height="44" Margin="0,0,4,0"
                                    Content="■" Command="{Binding StopCommand}" FontSize="14" />
                            <Button Width="52" Height="44"
                                    Content="►►" Command="{Binding NextCommand}" FontSize="14" />
                        </StackPanel>

                        <!-- Row 3: Library mode toggle + Add Source -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Button Width="108" Height="28" Margin="0,0,4,0"
                                    Content="{Binding LibraryModeText}" Command="{Binding ToggleLibraryModeCommand}" FontSize="11" />
                            <Button Width="108" Height="28"
                                    Content="{Binding AddSourceText}" Command="{Binding AddSourceCommand}" FontSize="11" />
                        </StackPanel>

                        <!-- Row 4: Volume slider (active only in Exclusive mode) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <TextBlock Text="Vol" FontSize="11" 
                                       VerticalAlignment="Center" Margin="0,0,4,0">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding VolumeTextColor}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                            <Slider Width="200" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05"
                                    Value="{Binding VolumeValue}" 
                                    IsEnabled="{Binding IsVolumeActive}" />
                        </StackPanel>

                        <!-- Row 5: Help + Collapse buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                            <Button Width="36" Height="36" Margin="0,0,4,0"
                                    Content="?" Command="{Binding ShowHelpCommand}" FontSize="14" />
                            <Button Width="36" Height="36"
                                    Content="{Binding ExpandIcon}" Command="{Binding ToggleExpandedCommand}" FontSize="14" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Window Control Buttons (Minimize / Close) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0">
                    <Button Width="20" Height="20" Margin="0,0,3,0" Content="─" FontSize="10" Padding="0"
                            Click="MinimizeButton_Click" ToolTip="Minimize" />
                    <Button Width="20" Height="20" Content="✕" FontSize="10" Padding="0"
                            Click="CloseButton_Click" ToolTip="Close" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Expanded Panel (initially hidden) -->
        <Grid Grid.Row="1" x:Name="ExpandedPanel" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}" Height="400">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /> <!-- Library -->
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" /> <!-- Playlist -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Library Header -->
            <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource HeaderBrush}" Padding="5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ExpandedPanel.LibraryTitle}" FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="4,0,8,0"
                               Foreground="{DynamicResource AccentBrush}" />
                    <TextBlock Text="{Binding ExpandedPanel.ScanStatusText}" FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="{Binding ExpandedPanel.ScanBlinkVisible, Converter={StaticResource BoolToVis}}"
                               Foreground="#FFA500" />
                    <!-- Search Box -->
                    <TextBox Text="{Binding ExpandedPanel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="120" Height="22" FontSize="11" Margin="8,0,0,0"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource SurfaceBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Visible" />
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </Border>

            <!-- Library Tree -->
            <TreeView Grid.Row="1" Grid.Column="0" Background="{DynamicResource SurfaceBrush}"
                      ItemsSource="{Binding ExpandedPanel.FilteredLibrary}"
                      BorderBrush="{DynamicResource BorderBrush}" Margin="5"
                      SelectedItemChanged="LibraryTreeView_SelectedItemChanged"
                      MouseDoubleClick="LibraryTreeView_MouseDoubleClick">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                            <Setter Property="Foreground" Value="#CCCCCC" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- Playlist Header -->
            <Border Grid.Row="0" Grid.Column="2" Background="{DynamicResource HeaderBrush}" Padding="5">
                <StackPanel Orientation="Horizontal">
                <Button Content="{Binding ExpandedPanel.UpText}"
                        Height="28" Width="40" Margin="0,0,4,0" FontSize="11"
                        Command="{Binding ExpandedPanel.PlaylistUpCommand}" />
                <Button Content="{Binding ExpandedPanel.DownText}"
                        Height="28" Width="40" Margin="0,0,4,0" FontSize="11"
                        Command="{Binding ExpandedPanel.PlaylistDownCommand}" />
                <Button Content="{Binding ExpandedPanel.DeleteText}"
                        Height="28" Width="30" Margin="0,0,4,0" FontSize="11"
                        Command="{Binding ExpandedPanel.PlaylistDeleteCommand}" />
                <Button Content="{Binding ExpandedPanel.ClearText}"
                        Height="28" Width="30" FontSize="11"
                        Command="{Binding ExpandedPanel.PlaylistClearCommand}" />
                </StackPanel>
            </Border>

            <!-- Playlist -->
            <ListBox Grid.Row="1" Grid.Column="2" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource AccentBrush}"
                     ItemsSource="{Binding ExpandedPanel.PlaylistItems}"
                     SelectedIndex="{Binding ExpandedPanel.SelectedPlaylistIndex}"
                     BorderBrush="{DynamicResource BorderBrush}" Margin="5"
                     MouseDoubleClick="Playlist_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Index, StringFormat='{}{0}'}" 
                                       FontSize="12" Foreground="#888888" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding AudioFile.Artist}" 
                                       FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="4,0,6,0" />
                            <TextBlock Grid.Column="2" Text="{Binding AudioFile.Title}" 
                                       FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Divider -->
            <GridSplitter Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="3" Background="{DynamicResource AccentBrush}" />
        </Grid>

        <!-- Loading Status Bar (bottom of window) -->
        <Border Grid.Row="2" Height="24" Background="{DynamicResource SurfaceBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding LoadingStatusText}" Foreground="#FFA500" FontSize="11"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </Border>
    </Grid>
</Window>
