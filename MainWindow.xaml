<Window x:Class="PureAudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PureAudio.ViewModels"
        xmlns:helpers="clr-namespace:PureAudio.Helpers"
        xmlns:controls="clr-namespace:PureAudio.Controls"
        mc:Ignorable="d"
        Title="PureAudio" Width="1000"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        ResizeMode="CanMinimize" WindowStartupLocation="Manual"
        Background="{DynamicResource BackgroundBrush}" WindowStyle="None" AllowsTransparency="False"
        FontFamily="Segoe UI Variable, Segoe UI, Helvetica, Arial, sans-serif"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <helpers:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════════
             TOP BAR — Hi-Fi Control Center (220px)
             Asymmetric layout: large cover art left, controls right,
             spectrum spanning the middle-right area
             ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Height="220"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="640" /> <!-- Display Area ~2/3 -->
                    <ColumnDefinition Width="280" /> <!-- Control Panel -->
                    <ColumnDefinition Width="80" />  <!-- Window buttons -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />   <!-- Main content -->
                    <RowDefinition Height="Auto" /> <!-- Bottom bar: Progress + Volume -->
                </Grid.RowDefinitions>

                <!-- ════════════════════════════════════════════════════════
                     ROW 0 — Main Content: Display Area (left) + Controls (right)
                     ════════════════════════════════════════════════════════ -->

                <!-- ── Left Side: Display Area ── -->
                <Grid Grid.Row="0" Grid.Column="0" Margin="10,5,5,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" /> <!-- Cover Art -->
                        <ColumnDefinition Width="*" />   <!-- Info -->
                        <ColumnDefinition Width="260" /> <!-- FFT Spectrum -->
                    </Grid.ColumnDefinitions>

                    <!-- ── Cover Art ── -->
                    <Border Grid.Column="0"
                            Width="180" Height="180"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            VerticalAlignment="Top"
                            Margin="0,8,0,0"
                            Effect="{DynamicResource CoverShadow}">
                        <Grid>
                            <Image Source="{Binding CoverPath}"
                                   Width="178" Height="178"
                                   Stretch="UniformToFill">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <Trigger Property="Source" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <!-- No-cover placeholder -->
                            <Border Background="#1A1A1A" CornerRadius="6"
                                    Width="178" Height="178">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Viewbox Width="48" Height="48" Opacity="0.3">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,3v10.55c-.59-.34-1.27-.55-2-.55-2.21,0-4,1.79-4,4s1.79,4,4,4,4-1.79,4-4V7h4V3h-6z"
                                              Fill="{DynamicResource AccentBrush}" />
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── Track Info (Marquee) ── -->
                    <TextBlock Grid.Column="1" Grid.ColumnSpan="2"
                               Text="{Binding MarqueeDisplayText}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               FontWeight="Medium"
                               TextTrimming="CharacterEllipsis"
                               Width="445"
                               Margin="10,8,0,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top" />

                    <!-- ── Info Area (right of cover) ── -->
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">

                        <!-- Timer Display — monospace for tabular figures -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding ElapsedText}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="22"
                                       FontFamily="Consolas"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2"
                                       Text="/"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="22"
                                       FontFamily="Consolas" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding TotalDurationText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="22"
                                       FontFamily="Consolas" />
                        </Grid>

                        <!-- Bitrate -->
                        <TextBlock Text="{Binding BitrateValue, StringFormat='{}{0} kbps'}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Margin="0,12,0,0" />

                        <!-- Large Status Label (BIT PERFECT / HI-Q SRC / STANDARD MODE) — mini-display style -->
                        <Border Background="#1B1B1B"
                                BorderBrush="#3A3A3A"
                                BorderThickness="1"
                                CornerRadius="4"
                                Width="170"
                                Height="28"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding StatusLabelText}"
                                       FontSize="16"
                                       FontWeight="Normal"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding StatusLabelColor}" />
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>

                        <!-- Play/Pause/Stop Indicators -->
                        <WrapPanel Margin="0,12,0,0">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="6,3"
                                    Margin="0,0,6,0">
                                <TextBlock Text="►"
                                           FontSize="10"
                                           FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding PlayIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="6,3"
                                    Margin="0,0,6,0">
                                <TextBlock Text="❚❚"
                                           FontSize="10"
                                           FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding PauseIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="4"
                                    Padding="6,3">
                                <TextBlock Text="■"
                                           FontSize="10"
                                           FontWeight="Bold">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding StopIndicatorColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <!-- ── FFT Spectrum (segmented bars, gold accent) ── -->
                    <Border Grid.Column="2"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Height="130"
                            Margin="5,44,0,0"
                            VerticalAlignment="Top"
                            x:Name="FftBorder">
                        <Grid x:Name="FftContainer" />
                    </Border>
                </Grid>

                <!-- ── Right Side: Control Panel (Row 0) ── -->
                <!--
                     Aligned to the FFT spectrum:
                     - Bit Perfect buttons top edge = spectrum top edge
                       (display area margin 5 + spectrum margin 44 = 49px from Row 0 top)
                     - Transport buttons bottom edge = spectrum bottom edge
                       (49 + spectrum height 130 = 179px from Row 0 top)
                     Control panel has Margin="0,5,0,0", so internal Y = Row 0 Y - 5.
                     Using fixed row heights that sum to 174px (179 - 5):
                       Row 0 (top spacer): 44px
                       Row 1 (buttons):    Auto (~30px)
                       Row 2 (spacer):     * fills remaining
                       Row 3 (transport):  Auto (~44px)
                       Row 4 (bottom):     56px - Row2Height
                     Total fixed: 44 + 30 + 44 = 118px, bottom spacer = 174 - 118 = 56px
                     The * row absorbs any extra height so transport stays at bottom.
                -->
                <Grid Grid.Row="0" Grid.Column="1"
                      Width="240"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Height="174"
                      Margin="0,5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />  <!-- Top spacer: aligns button top with spectrum top -->
                        <RowDefinition Height="Auto" /> <!-- Toggles (Bit Perfect buttons) -->
                        <RowDefinition Height="*" />    <!-- Spacer -->
                        <RowDefinition Height="Auto" /> <!-- Transport -->
                    </Grid.RowDefinitions>



                    <!-- Row 1: Bit Perfect toggle + Lossless/Compressed toggle + Bit-Perfect Indicator -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="3,0,0,0">
                        <Button Width="120" Height="30"
                                Margin="0,0,8,0"
                                Content="{Binding BitPerfectButtonText}"
                                Command="{Binding BitPerfectCommand}"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{Binding BitPerfectButtonColor, Converter={StaticResource ColorToBrushConverter}}"
                                BorderBrush="{Binding BitPerfectBorderColor, Converter={StaticResource ColorToBrushConverter}}" />
                        <Button Width="108" Height="30"
                                Margin="0,0,8,0"
                                Content="{Binding LibraryModeText}"
                                Command="{Binding ToggleLibraryModeCommand}"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="{Binding HiresIndicatorColor, Converter={StaticResource ColorToBrushConverter}}"
                                BorderBrush="{Binding HiresIndicatorColor, Converter={StaticResource ColorToBrushConverter}}" />
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="4"
                                Padding="8,4"
                                Height="30"
                                VerticalAlignment="Center"
                                ToolTip="{Binding BitPerfectInfoText}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BitDepthText}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding BitDepthColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <TextBlock Text="  "
                                           FontSize="13"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Foreground="#555555" />
                                <TextBlock Text="{Binding SampleRateText}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding SampleRateColor}" />
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Row 2: Source + DAC info rows (spacer area between buttons and transport) -->
                    <StackPanel Grid.Row="2"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="6,0,0,0">
                        <!-- Source row: "Source: 24 bit / 96 kHz ●" -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Source:"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=" "
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SourceFormatText}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="  "
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <!-- Status indicator dot -->
                            <Ellipse Width="8" Height="8"
                                     VerticalAlignment="Center"
                                     Margin="0,0,0,0">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding SourceIndicatorColor}" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </StackPanel>
                        <!-- DAC row: "DAC: 16-24 bit / 44.1-48 kHz" -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="DAC:"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#888888"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=" "
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding DacCapabilitiesText}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="#CCCCCC"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Row 3: Transport Controls — aligned to bottom (level with FFT bottom edge) -->
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,0">
                        <Button Width="52" Height="44"
                                Margin="0,0,6,0"
                                Content="◄◄"
                                Command="{Binding PreviousCommand}"
                                FontSize="13"
                                Style="{StaticResource GhostButtonStyle}" />
                        <Button Width="60" Height="44"
                                Margin="0,0,6,0"
                                Style="{StaticResource AccentButtonStyle}"
                                Content="{Binding PlayPauseIcon}"
                                Command="{Binding PlayPauseCommand}"
                                FontSize="16" />
                        <Button Width="52" Height="44"
                                Margin="0,0,6,0"
                                Content="■"
                                Command="{Binding StopCommand}"
                                FontSize="13"
                                Style="{StaticResource GhostButtonStyle}" />
                        <Button Width="52" Height="44"
                                Content="►►"
                                Command="{Binding NextCommand}"
                                FontSize="13"
                                Style="{StaticResource GhostButtonStyle}" />
                    </StackPanel>
                </Grid>



                <!-- ── Window Control Buttons (horizontal) ── -->
                <StackPanel Grid.Row="0" Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,6,6,0">
                    <Button Width="22" Height="22"
                            Margin="0,0,4,0"
                            Content="─"
                            FontSize="10"
                            Padding="0"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize"
                            Style="{StaticResource GhostButtonStyle}" />
                    <Button Width="22" Height="22"
                            Content="✕"
                            FontSize="10"
                            Padding="0"
                            Click="CloseButton_Click"
                            ToolTip="Close"
                            Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>
                <!-- Help + Expand (vertical, below window buttons) -->
                <StackPanel Grid.Row="0" Grid.Column="2"
                            Orientation="Vertical"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,34,6,0">
                    <Button Width="22" Height="22"
                            Margin="0,0,0,4"
                            Content="?"
                            Command="{Binding ShowHelpCommand}"
                            FontSize="11"
                            Padding="0"
                            ToolTip="Help"
                            Style="{StaticResource GhostButtonStyle}" />
                    <Button Width="22" Height="22"
                            Content="{Binding ExpandIcon}"
                            Command="{Binding ToggleExpandedCommand}"
                            FontSize="11"
                            Padding="0"
                            ToolTip="Toggle Expanded View"
                            Style="{StaticResource GhostButtonStyle}" />
                </StackPanel>

                <!-- ════════════════════════════════════════════════════════
                     ROW 1 — Bottom Bar: Progress Bar (left) + Volume (right)
                     ════════════════════════════════════════════════════════ -->

                <!-- ── Progress Bar (left side, spans col 0) ── -->
                <Slider Grid.Row="1" Grid.Column="0"
                        Value="{Binding Progress}"
                        Minimum="0" Maximum="1"
                        Margin="10,0,10,0"
                        Height="20"
                        VerticalAlignment="Center"
                        Thumb.DragStarted="ProgressSlider_DragStarted"
                        Thumb.DragCompleted="ProgressSlider_DragCompleted"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown" />

                <!-- ── Volume (right side, col 1) ── -->
                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,0,0,6">
                    <TextBlock Text="Vol"
                               FontSize="11"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{Binding VolumeTextColor}" />
                        </TextBlock.Foreground>
                    </TextBlock>
                    <Slider Width="200"
                            Minimum="0" Maximum="1"
                            SmallChange="0.01" LargeChange="0.05"
                            Value="{Binding VolumeValue}"
                            IsEnabled="{Binding IsVolumeActive}" />
                </StackPanel>
            </Grid>
        </Border>


        <!-- ════════════════════════════════════════════════════════════
             EXPANDED PANEL — Library + Playlist
             ════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              x:Name="ExpandedPanel"
              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
              Height="400">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />   <!-- Library -->
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />   <!-- Playlist -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Library Header ── -->
            <Border Grid.Row="0" Grid.Column="0"
                    Background="{DynamicResource HeaderBrush}"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ExpandedPanel.LibraryTitle}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="4,0,12,0"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="{Binding ExpandedPanel.ScanStatusText}"
                               FontSize="11"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Visibility="{Binding ExpandedPanel.ScanBlinkVisible, Converter={StaticResource BoolToVis}}"
                               Foreground="{DynamicResource AccentBrush}" />
                    <!-- Search Box -->
                    <TextBox Text="{Binding ExpandedPanel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="100" Height="24"
                             FontSize="11"
                             Margin="8,0,4,0"
                             VerticalAlignment="Center" />
                    <!-- Separator between search and library management buttons -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="6,2,6,2" />
                    <!-- Remove Source Button -->
                    <Button Content="{Binding ExpandedPanel.DeleteLibrarySourceText}"
                            Width="24" Height="24"
                            FontSize="12"
                            VerticalAlignment="Center"
                            ToolTip="Remove selected source folder from library"
                            Command="{Binding ExpandedPanel.DeleteLibrarySourceCommand}" />
                    <!-- Refresh Library Button -->
                    <Button Content="{Binding ExpandedPanel.RefreshLibraryText}"
                            Width="24" Height="24"
                            FontSize="14"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Rescan library sources for new files"
                            Command="{Binding ExpandedPanel.RefreshLibraryCommand}" />
                    <!-- Add Source Button -->
                    <Button Content="{Binding AddSourceText}"
                            Width="150" Height="24"
                            FontSize="12"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="Add a source folder to the library"
                            Command="{Binding AddSourceCommand}" />
                </StackPanel>
            </Border>

            <!-- ── Library Tree ── -->
            <TreeView Grid.Row="1" Grid.Column="0"
                      Background="{DynamicResource SurfaceBrush}"
                      ItemsSource="{Binding ExpandedPanel.FilteredLibrary}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      Margin="5"
                      SelectedItemChanged="LibraryTreeView_SelectedItemChanged"
                      MouseDoubleClick="LibraryTreeView_MouseDoubleClick">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Padding" Value="2,3" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Expand/Collapse toggle -->
                                        <ToggleButton x:Name="Expander"
                                                      Grid.Column="0"
                                                      ClickMode="Press"
                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Style="{StaticResource ExpandCollapseToggleStyle}"
                                                      Visibility="Hidden" />
                                        <!-- Content area with selection highlight -->
                                        <Border x:Name="Bd"
                                                Grid.Column="1"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter x:Name="PART_Header"
                                                              ContentSource="Header"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                        </Border>
                                        <!-- Items host -->
                                        <ItemsPresenter x:Name="ItemsHost"
                                                        Grid.Row="1"
                                                        Grid.Column="1"
                                                        Visibility="Collapsed" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="HasItems" Value="True">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <Trigger Property="IsExpanded" Value="True">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#383838" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#C9A84C" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E2E2E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <!-- ── Playlist Header ── -->
            <Border Grid.Row="0" Grid.Column="2"
                    Background="{DynamicResource HeaderBrush}"
                    Padding="8,6">
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding ExpandedPanel.UpText}"
                            Height="28" Width="40"
                            Margin="0,0,6,0"
                            FontSize="11"
                            Command="{Binding ExpandedPanel.PlaylistUpCommand}" />
                    <Button Content="{Binding ExpandedPanel.DownText}"
                            Height="28" Width="40"
                            Margin="0,0,6,0"
                            FontSize="11"
                            Command="{Binding ExpandedPanel.PlaylistDownCommand}" />
                    <Button Content="{Binding ExpandedPanel.DeleteText}"
                            Height="28" Width="36"
                            Margin="0,0,6,0"
                            FontSize="11"
                            Command="{Binding ExpandedPanel.PlaylistDeleteCommand}" />
                    <Button Content="{Binding ExpandedPanel.ClearText}"
                            Height="28" Width="36"
                            Margin="0,0,6,0"
                            FontSize="11"
                            Command="{Binding ExpandedPanel.PlaylistClearCommand}" />
                    <!-- Spacer between queue controls and named playlist controls -->
                    <Rectangle Width="16" Fill="Transparent" />
                    <!-- Named playlist buttons -->
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,2" />
                    <Button Content="{Binding ExpandedPanel.SavePlaylistText}"
                            Height="28" Width="40"
                            Margin="0,0,4,0"
                            FontSize="11"
                            ToolTip="Save current playlist"
                            Command="{Binding ExpandedPanel.SavePlaylistCommand}" />
                    <Button Content="{Binding ExpandedPanel.LoadPlaylistText}"
                            Height="28" Width="40"
                            Margin="0,0,4,0"
                            FontSize="11"
                            ToolTip="Load a saved playlist"
                            Command="{Binding ExpandedPanel.LoadPlaylistCommand}" />
                    <Button Content="{Binding ExpandedPanel.RenamePlaylistText}"
                            Height="28" Width="52"
                            Margin="0,0,4,0"
                            FontSize="11"
                            ToolTip="Rename current playlist"
                            Command="{Binding ExpandedPanel.RenamePlaylistCommand}" />
                    <Button Content="{Binding ExpandedPanel.DeletePlaylistText}"
                            Height="28" Width="36"
                            Margin="0,0,0,0"
                            FontSize="11"
                            ToolTip="Delete current playlist"
                            Command="{Binding ExpandedPanel.DeletePlaylistCommand}" />

                </StackPanel>
            </Border>


            <!-- ── Playlist ── -->
            <ListBox Grid.Row="1" Grid.Column="2"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     ItemsSource="{Binding ExpandedPanel.PlaylistItems}"
                     SelectedIndex="{Binding ExpandedPanel.SelectedPlaylistIndex}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     Margin="5"
                     MouseDoubleClick="Playlist_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="Padding" Value="4,3" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#383838" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#C9A84C" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E2E2E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Index, StringFormat='{}{0}'}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AudioFile.Artist}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="4,0,6,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding AudioFile.Title}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ── Divider ── -->
            <GridSplitter Grid.Row="0" Grid.RowSpan="2"
                          Grid.Column="1"
                          Width="3"
                          Background="{DynamicResource BorderBrush}"
                          Margin="2,0" />
        </Grid>

        <!-- ════════════════════════════════════════════════════════════
             LOADING STATUS BAR
             ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Height="24"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding LoadingStatusText}"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="11"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
        </Border>
    </Grid>
</Window>
