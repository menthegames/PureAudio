<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         PureAudio — Hi-Fi Design System
         Based on SKILL.md aesthetic guidelines:
         • Off-black backgrounds, no pure #000
         • Gold accent (#C9A84C) — single accent color
         • No red, no blue
         • Flat design with subtle depth
         ============================================================ -->

    <!-- ── Core Palette ── -->
    <!-- Background: graphite gray (warm, premium, not pure black) -->
    <Color x:Key="BackgroundColor">#1C1C1C</Color>
    <!-- Surface: slightly lighter for cards/panels -->
    <Color x:Key="SurfaceColor">#252525</Color>
    <!-- Header: subtle elevation -->
    <Color x:Key="HeaderColor">#2E2E2E</Color>
    <!-- Gold accent — warm, premium, single accent -->
    <Color x:Key="AccentColor">#C9A84C</Color>
    <!-- Button background: dark but distinguishable -->
    <Color x:Key="ButtonBgColor">#333333</Color>
    <!-- Button hover: lighter for glow effect -->
    <Color x:Key="ButtonHoverColor">#444444</Color>
    <!-- Button pressed: darker for tactile feedback -->
    <Color x:Key="ButtonPressedColor">#262626</Color>
    <!-- Border: subtle separation -->
    <Color x:Key="BorderColor">#3A3A3A</Color>
    <!-- Text primary: warm white -->
    <Color x:Key="TextColor">#E8E0D0</Color>
    <!-- Text secondary: muted gray -->
    <Color x:Key="TextSecondaryColor">#999999</Color>
    <!-- Text muted: very subtle -->
    <Color x:Key="TextMutedColor">#666666</Color>
    <!-- Gold glow (for hover effects) -->
    <Color x:Key="GoldGlowColor">#C9A84C</Color>
    <!-- Button border: subtle outline for physical look -->
    <Color x:Key="ButtonBorderColor">#4A4A4A</Color>
    <!-- Button inner shadow (darker) -->
    <Color x:Key="ButtonInnerShadowColor">#1A1A1A</Color>

    <!-- ── Brushes ── -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="HeaderBrush" Color="{StaticResource HeaderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="ButtonBgBrush" Color="{StaticResource ButtonBgColor}" />
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="{StaticResource ButtonHoverColor}" />
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="{StaticResource ButtonPressedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="{StaticResource ButtonBorderColor}" />
    <SolidColorBrush x:Key="ButtonInnerShadowBrush" Color="{StaticResource ButtonInnerShadowColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />

    <!-- ── Gold glow effect brush (semi-transparent gold for hover glow) ── -->
    <SolidColorBrush x:Key="GoldGlowBrush" Color="{StaticResource GoldGlowColor}" Opacity="0.3" />

    <!-- ============================================================
         GLOBAL BUTTON STYLE — Physical button look with subtle depth
         • Subtle border for definition (like physical button edges)
         • Inner shadow for depth (dark bottom edge)
         • Gold glow on hover
         • Scale-down on press for tactile feedback
         ============================================================ -->
    <Style TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{StaticResource ButtonBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Helvetica, Arial, sans-serif" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Inner shadow overlay (dark at bottom for depth) -->
                            <Border x:Name="innerShadow"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource ButtonInnerShadowBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="7"
                                    Opacity="0.5"
                                    Margin="1,1,1,0"
                                    IsHitTestVisible="False" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="True" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover: gold glow effect + lighter border -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonHoverBrush}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="14"
                                                      Color="{StaticResource GoldGlowColor}"
                                                      Opacity="0.45" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Pressed: tactile feedback — deeper press -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonPressedBrush}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}" />
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="6"
                                                      Color="{StaticResource GoldGlowColor}"
                                                      Opacity="0.15" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="innerShadow" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                            <Setter TargetName="border" Property="Background" Value="{StaticResource SurfaceBrush}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Accent Button (gold background, dark text) ── -->
    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#D4B85A" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#B8973E" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Ghost Button (transparent bg, gold text on hover) ── -->
    <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                <Setter Property="Background" Value="#1A1A1A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================================
         GLOBAL SLIDER STYLE — Minimal, gold accent
         ============================================================ -->
    <Style TargetType="Slider">
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="1" />
        <Setter Property="TickFrequency" Value="0.01" />
        <Setter Property="IsSnapToTickEnabled" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource ButtonBgBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ============================================================
         GLOBAL TEXTBOX STYLE
         ============================================================ -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Helvetica, Arial, sans-serif" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="border" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="8"
                                                      Color="{StaticResource GoldGlowColor}"
                                                      Opacity="0.3" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         GLOBAL LISTBOX STYLE
         ============================================================ -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Helvetica, Arial, sans-serif" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ============================================================
         GLOBAL TREEVIEW STYLE
         ============================================================ -->
    <Style TargetType="TreeView">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Helvetica, Arial, sans-serif" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ============================================================
         GLOBAL SCROLLBAR STYLE (minimal, dark)
         ============================================================ -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonBgBrush}" />
    </Style>

    <!-- ============================================================
         EXPAND/COLLAPSE TOGGLE STYLE — for TreeView expander arrows
         Minimal dark style matching the Hi-Fi aesthetic
         ============================================================ -->
    <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent"
                            Width="16"
                            Height="16"
                            SnapsToDevicePixels="True">
                        <Path x:Name="Arrow"
                              Data="M0,0 L0,8 L6,4 Z"
                              Fill="{DynamicResource TextMutedBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform Angle="0" />
                            </Path.RenderTransform>
                        </Path>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================
         PULSING DOT ANIMATION — for background activity indicator
         Smooth opacity oscillation for a subtle "alive" effect
         ============================================================ -->
    <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                       Duration="0:0:1.2"
                                       AutoReverse="True">
            <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0" />
            <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="0.2" />
            <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1.0">
                <EasingDoubleKeyFrame.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </EasingDoubleKeyFrame.EasingFunction>
            </EasingDoubleKeyFrame>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

</ResourceDictionary>


