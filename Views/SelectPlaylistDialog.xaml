<Window x:Class="PureAudio.Views.SelectPlaylistDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Playlist"
        Width="360" Height="300"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1C1C1C"
        AllowsTransparency="False"
        FontFamily="Segoe UI Variable, Segoe UI, Helvetica, Arial, sans-serif"
        ShowInTaskbar="False">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Resources/Styles.xaml" />

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="#3A3A3A" BorderThickness="1" CornerRadius="8">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="Select a playlist:"
                       Foreground="#E8E0D0"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <!-- Playlist List -->
            <ListBox x:Name="PlaylistListBox"
                     Grid.Row="1"
                     Background="#252525"
                     Foreground="#E8E0D0"
                     BorderBrush="#3A3A3A"
                     BorderThickness="1"
                     FontSize="13"
                     Margin="0,0,0,12"
                     MouseDoubleClick="PlaylistListBox_MouseDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="#E8E0D0" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#383838" />
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#C9A84C" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2E2E2E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="80" Height="30"
                        Margin="0,0,8,0"
                        FontSize="12"
                        IsCancel="True"
                        Click="CancelButton_Click" />
                <Button Content="OK"
                        Width="80" Height="30"
                        FontSize="12"
                        FontWeight="SemiBold"
                        IsDefault="True"
                        Click="OkButton_Click"
                        Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
